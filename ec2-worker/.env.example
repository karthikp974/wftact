# Copy from wftact .env.local on your PC (do not commit .env)

NEXT_PUBLIC_SUPABASE_URL=https://gtooxwzvybsgwkzhlfgb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Send mail via Brevo SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=karthik@workflowtech.info
SMTP_PASS=your-brevo-smtp-api-key
# or: BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM_NAME=WorkflowTech
EMAIL_FROM_ADDRESS=karthik@workflowtech.info

# --- Reply detection still uses Titan inbox ---
IMAP_HOST=imap.titan.email
IMAP_PORT=993
IMAP_USER=karthik@workflowtech.info
IMAP_PASS=your-titan-mailbox-password

DEMO_URL=https://demo.workflowtech.info
OUTREACH_THROTTLE_MS=3000

# 45 min after mail open
FOLLOWUP_DELAY_MS=2700000
# check every 5 min
FOLLOWUP_POLL_MS=300000
