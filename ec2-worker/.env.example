# Copy from wftact .env.local on your PC (do not commit .env)

NEXT_PUBLIC_SUPABASE_URL=https://gtooxwzvybsgwkzhlfgb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Titan SMTP — Mail 1, follow-ups, nurture (Option C)
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=karthik@workflowtech.info
SMTP_PASS=your-titan-password
